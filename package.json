{
  "name": "rnd-data-processing",
  "private": true,
  "version": "0.1.0",
  "license": "MIT",
  "packageManager": "bun@1.3.14",
  "description": "Offline System 208V accuracy report processing desktop app.",
  "author": "Syed Hassaan Shah",
  "type": "module",
  "scripts": {
    "dev": "bun --bun vite --config frontend/vite.config.ts",
    "dev:frontend": "bun --bun vite --config frontend/vite.config.ts",
    "build": "bun --bun tsc -b && bun --bun vite build --config frontend/vite.config.ts",
    "build:frontend": "bun --bun tsc -b && bun --bun vite build --config frontend/vite.config.ts",
    "tauri": "tauri",
    "desktop": "bun run tauri dev --features desktop --config backend/tauri.conf.json",
    "dev:desktop": "bun run tauri dev --features desktop --config backend/tauri.conf.json",
    "build:desktop": "bun run tauri build --features desktop --config backend/tauri.conf.json --bundles nsis",
    "build:desktop:unsigned": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/build-unsigned-installer.ps1",
    "test": "bun --bun vitest run --config frontend/vite.config.ts",
    "test:frontend": "bun --bun vitest run --config frontend/vite.config.ts",
    "check:versions": "node scripts/check-version-consistency.mjs",
    "check:tauri-cli": "node scripts/check-local-tauri-cli.mjs",
    "pipeline": "cargo run --manifest-path backend/Cargo.toml --bin rnd-pipeline --"
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2",
    "@tauri-apps/plugin-opener": "^2",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "lucide-react": "^1.8.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.4",
    "@tauri-apps/cli": "^2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "jsdom": "^29.0.2",
    "tailwindcss": "^4.2.4",
    "typescript": "~6.0.2",
    "vite": "^8.0.9",
    "vitest": "^4.1.5"
  }
}
